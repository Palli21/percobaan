<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptDataAlergiPasien" pageWidth="1391" pageHeight="595" orientation="Landscape" columnWidth="1351" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="20"/>
	<property name="ireport.y" value="0"/>
	<parameter name="namars" class="java.lang.String"/>
	<parameter name="alamatrs" class="java.lang.String"/>
	<parameter name="kotars" class="java.lang.String"/>
	<parameter name="propinsirs" class="java.lang.String"/>
	<parameter name="kontakrs" class="java.lang.String"/>
	<parameter name="emailrs" class="java.lang.String"/>
	<parameter name="logo" class="java.io.InputStream"/>
	<queryString>
		<![CDATA[select alergi_pasien.no_rawat,reg_periksa.no_rkm_medis,pasien.nm_pasien,
DATE_FORMAT(alergi_pasien.tgl_perawatan,'%d-%m-%Y %H:%i:%s') as tgl_input,
alergi_pasien.allergy_code,satu_sehat_ref_allergy.display as nama_alergi,alergi_pasien.category,
alergi_pasien.reactioncode,satu_sehat_ref_allergy_reaction.display as nama_reaksi,alergi_pasien.severity,
alergi_pasien.note,pegawai.nama as nama_petugas
from reg_periksa inner join pasien on reg_periksa.no_rkm_medis=pasien.no_rkm_medis
inner join alergi_pasien on reg_periksa.no_rawat=alergi_pasien.no_rawat
inner join pegawai on alergi_pasien.nippetugas=pegawai.nik
inner join satu_sehat_ref_allergy on alergi_pasien.allergy_code=satu_sehat_ref_allergy.kode
inner join satu_sehat_ref_allergy_reaction on alergi_pasien.reactioncode=satu_sehat_ref_allergy_reaction.kode]]>
	</queryString>
	<field name="no_rawat" class="java.lang.String"/>
	<field name="no_rkm_medis" class="java.lang.String"/>
	<field name="nm_pasien" class="java.lang.String"/>
	<field name="tgl_input" class="java.lang.String"/>
	<field name="allergy_code" class="java.lang.String"/>
	<field name="nama_alergi" class="java.lang.String"/>
	<field name="category" class="java.lang.String"/>
	<field name="reactioncode" class="java.lang.String"/>
	<field name="nama_reaksi" class="java.lang.String"/>
	<field name="severity" class="java.lang.String"/>
	<field name="note" class="java.lang.String"/>
	<field name="nama_petugas" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band height="84" splitType="Stretch">
			<staticText>
				<reportElement x="1" y="51" width="1349" height="23"/>
				<textElement textAlignment="Center" lineSpacing="Single">
					<font fontName="Tahoma" size="11" isBold="false"/>
				</textElement>
				<text><![CDATA[DATA ALERGI PASIEN]]></text>
			</staticText>
			<textField>
				<reportElement x="3" y="14" width="1347" height="14"/>
				<textElement textAlignment="Center" lineSpacing="Single">
					<font fontName="Tahoma" size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$P{alamatrs}+", "+$P{kotars}+", "+$P{propinsirs}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="3" y="0" width="1347" height="17"/>
				<textElement textAlignment="Center" lineSpacing="Single">
					<font fontName="Tahoma" size="12"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$P{namars}]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="1" y="48" width="1349" height="1"/>
				<graphicElement>
					<pen lineWidth="2.0" lineStyle="Double"/>
				</graphicElement>
			</line>
			<textField>
				<reportElement x="3" y="35" width="1347" height="14"/>
				<textElement textAlignment="Center" lineSpacing="Single">
					<font fontName="Tahoma" size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA["E-mail : "+$P{emailrs}]]></textFieldExpression>
			</textField>
			<image scaleImage="FillFrame" onErrorType="Blank">
				<reportElement x="1" y="2" width="48" height="45"/>
				<imageExpression class="java.io.InputStream"><![CDATA[$P{logo}]]></imageExpression>
			</image>
			<textField>
				<reportElement x="3" y="25" width="1347" height="14"/>
				<textElement textAlignment="Center" lineSpacing="Single">
					<font fontName="Tahoma" size="9"/>
				</textElement>
				<textFieldExpression class="java.lang.String"><![CDATA[$P{kontakrs}]]></textFieldExpression>
			</textField>
		</band>
	</title>
	<pageHeader>
		<band splitType="Stretch"/>
	</pageHeader>
	<columnHeader>
