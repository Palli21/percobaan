				<textElement verticalAlignment="Middle"><font fontName="Tahoma" size="8"/></textElement>
				<text><![CDATA[KODE REAKSI]]></text>
			</staticText>
			<staticText>
				<reportElement mode="Opaque" x="805" y="0" width="160" height="16" backcolor="#F0F0DC"/>
				<textElement verticalAlignment="Middle"><font fontName="Tahoma" size="8"/></textElement>
				<text><![CDATA[REAKSI]]></text>
			</staticText>
