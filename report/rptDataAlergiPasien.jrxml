	</columnHeader>
	<detail>
		<band height="11" splitType="Stretch">
			<textField isStretchWithOverflow="true"><reportElement x="2" y="0" width="81" height="10"/><textElement><font fontName="Tahoma" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{no_rawat}]]></textFieldExpression></textField>
			<textField isStretchWithOverflow="true"><reportElement x="85" y="0" width="58" height="10"/><textElement><font fontName="Tahoma" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{no_rkm_medis}]]></textFieldExpression></textField>
			<textField isStretchWithOverflow="true"><reportElement x="145" y="0" width="138" height="10"/><textElement><font fontName="Tahoma" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{nm_pasien}]]></textFieldExpression></textField>
			<textField isStretchWithOverflow="true"><reportElement x="285" y="0" width="108" height="10"/><textElement><font fontName="Tahoma" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{tgl_input}]]></textFieldExpression></textField>
			<textField isStretchWithOverflow="true"><reportElement x="395" y="0" width="78" height="10"/><textElement><font fontName="Tahoma" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{allergy_code}]]></textFieldExpression></textField>
			<textField isStretchWithOverflow="true"><reportElement x="475" y="0" width="178" height="10"/><textElement><font fontName="Tahoma" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{nama_alergi}]]></textFieldExpression></textField>
			<textField isStretchWithOverflow="true"><reportElement x="655" y="0" width="68" height="10"/><textElement><font fontName="Tahoma" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{category}]]></textFieldExpression></textField>
			<textField isStretchWithOverflow="true"><reportElement x="725" y="0" width="78" height="10"/><textElement><font fontName="Tahoma" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{reactioncode}]]></textFieldExpression></textField>
			<textField isStretchWithOverflow="true"><reportElement x="805" y="0" width="158" height="10"/><textElement><font fontName="Tahoma" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA[$F{nama_reaksi}]]></textFieldExpression></textField>
